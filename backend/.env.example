# -----------------------------------------------------------------------
# Inventory Simulation – backend environment variables
# -----------------------------------------------------------------------
# Copy this file to .env and fill in your values.
# The .env file is gitignored and must never be committed.

# Postgres/Neon connection string.
# Accepted formats:
#   postgresql://user:pass@host/dbname?sslmode=require   (standard)
#   postgres://user:pass@host/dbname                     (PaaS shorthand)
#
# For Neon: copy the connection string from the Neon dashboard.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Optional: maximum upload size in megabytes (default: 10)
# MAX_UPLOAD_MB=10
